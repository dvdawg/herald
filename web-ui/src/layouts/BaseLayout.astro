---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";

export interface Props {
  title?: string;
}

const { title = "Herald" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[radial-gradient(circle_at_top,rgba(180,76,47,0.14),transparent_32%),linear-gradient(180deg,#fbf7ef_0%,#f4f0e8_100%)] text-ink">
    <SiteHeader />
    <slot />
  </body>
</html>
