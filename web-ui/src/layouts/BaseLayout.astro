---
import SiteHeader from "../components/SiteHeader.astro";

export interface Props {
  title?: string;
  activePage?: "papers" | "news";
}

const { title = "Herald", activePage = "papers" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <SiteHeader activePage={activePage} />
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f4f0e8;
    --panel: #fffdf8;
    --panel-strong: #f8f2e5;
    --ink: #181511;
    --muted: #5f564a;
    --line: #181511;
    --line-soft: rgba(24, 21, 17, 0.18);
    --accent: #b44c2f;
    --shadow: 8px 8px 0 rgba(24, 21, 17, 0.08);
    --radius: 18px;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    font-family: "IBM Plex Sans", "Avenir Next", Avenir, "Segoe UI", sans-serif;
    background:
      radial-gradient(circle at top, rgba(180, 76, 47, 0.14), transparent 32%),
      linear-gradient(180deg, #fbf7ef 0%, var(--bg) 100%);
    color: var(--ink);
  }

  a {
    color: inherit;
  }

  button,
  input,
  textarea {
    font: inherit;
  }

  .page-shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: 32px 20px 48px;
  }

  .hero {
    border: 2px solid var(--line);
    border-radius: calc(var(--radius) + 6px);
    background:
      linear-gradient(135deg, rgba(180, 76, 47, 0.08), transparent 56%),
      var(--panel);
    box-shadow: var(--shadow);
    padding: 24px;
    margin-bottom: 22px;
  }

  .hero-kicker {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hero h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.7rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    max-width: 10ch;
  }

  .hero p {
    margin: 16px 0 0;
    max-width: 60ch;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.5;
  }

  .panel-grid {
    display: grid;
    grid-template-columns: minmax(280px, 340px) minmax(0, 1fr);
    gap: 18px;
    align-items: start;
  }

  .panel {
    border: 2px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    box-shadow: var(--shadow);
  }

  .panel-inner {
    padding: 18px;
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: baseline;
    margin-bottom: 16px;
  }

  .panel-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .panel-chip {
    border: 1.5px solid var(--line);
    border-radius: 999px;
    padding: 4px 10px;
    background: var(--panel-strong);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .field {
    margin-bottom: 14px;
  }

  .field:last-of-type {
    margin-bottom: 18px;
  }

  .field--row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .field--row .field {
    margin-bottom: 0;
  }

  .field--row .field-hint {
    grid-column: 1 / -1;
  }

  .field label {
    display: block;
    margin-bottom: 6px;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .field-hint {
    display: block;
    margin-top: 5px;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.35;
  }

  .input,
  .textarea {
    width: 100%;
    border: 1.5px solid var(--line);
    border-radius: 12px;
    background: #fff;
    color: var(--ink);
    padding: 11px 12px;
  }

  .textarea {
    resize: vertical;
    min-height: 108px;
  }

  .actions {
    display: flex;
    justify-content: flex-start;
  }

  .source-fieldset {
    border: 1.5px solid var(--line);
    border-radius: 14px;
    padding: 14px 14px 10px;
    background: #fff;
  }

  .source-fieldset legend {
    padding: 0 8px;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .checkbox-row {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 10px;
    font-size: 0.95rem;
  }

  .checkbox-row input {
    width: 16px;
    height: 16px;
  }

  .button {
    border: 2px solid var(--line);
    border-radius: 12px;
    background: var(--ink);
    color: #fffdf8;
    padding: 10px 16px;
    font-weight: 700;
    cursor: pointer;
  }

  .button[disabled] {
    opacity: 0.72;
    cursor: wait;
  }

  .status-message {
    min-height: 1.25rem;
    margin-bottom: 14px;
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--accent);
  }

  .status-meta {
    margin: -8px 0 14px;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .results-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .result-item {
    border: 2px solid var(--line);
    border-radius: 14px;
    background: #fff;
    overflow: hidden;
  }

  .result-item__row {
    display: grid;
    grid-template-columns: 88px minmax(0, 1fr);
  }

  .result-rank {
    border-right: 2px solid var(--line);
    background: var(--panel-strong);
    padding: 14px 12px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 4px;
  }

  .result-rank__label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .result-rank__value {
    font-size: 1.8rem;
    line-height: 1;
    font-weight: 700;
    letter-spacing: -0.05em;
  }

  .result-body {
    padding: 14px 16px 16px;
  }

  .result-body h3 {
    margin: 0 0 10px;
    font-size: 1.05rem;
    line-height: 1.3;
  }

  .result-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 10px;
  }

  .result-metric {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 9px;
    background: var(--panel-strong);
    font-size: 0.8rem;
    line-height: 1.2;
  }

  .result-metric strong {
    margin-right: 4px;
  }

  .result-authors {
    margin: 0 0 10px;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .result-summary {
    margin: 0;
    line-height: 1.55;
    color: #2f2923;
  }

  .result-link {
    display: inline-block;
    margin-top: 12px;
    font-weight: 700;
    text-decoration: none;
    border-bottom: 2px solid var(--line);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 8px;
    background: rgba(180, 76, 47, 0.08);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .empty-state {
    border: 2px dashed var(--line-soft);
    border-radius: 14px;
    padding: 18px;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.55);
  }

  .debug-block {
    margin-top: 16px;
    border-top: 2px solid var(--line);
    padding-top: 16px;
  }

  .debug-block h3 {
    margin: 0 0 10px;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .debug-block pre {
    margin: 0;
    border: 1.5px solid var(--line);
    border-radius: 12px;
    padding: 12px;
    background: #fff;
    white-space: pre-wrap;
    word-break: break-word;
    overflow-x: auto;
  }

  @media (max-width: 900px) {
    .panel-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .page-shell {
      padding-inline: 14px;
    }

    .hero,
    .panel-inner {
      padding: 16px;
    }

    .field--row {
      grid-template-columns: 1fr;
    }

    .result-item__row {
      grid-template-columns: 1fr;
    }

    .result-rank {
      border-right: 0;
      border-bottom: 2px solid var(--line);
      flex-direction: row;
      align-items: center;
    }
  }
</style>
