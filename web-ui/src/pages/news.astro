---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsResultsPanel from "../components/NewsResultsPanel.astro";
import NewsSearchPanel from "../components/NewsSearchPanel.astro";
import runNewsScript from "../scripts/news.js?url";
---

<BaseLayout title="Herald News Radar" activePage="news">
  <main class="page-shell page-shell--news">
    <section class="hero hero--news">
      <div>
        <p class="hero-kicker">Herald News</p>
        <h1>Current events arranged like a morning briefing.</h1>
      </div>
      <div class="hero-news__badge">
        <span>Live feed</span>
        <strong>Communities + news desks</strong>
      </div>
    </section>

    <div class="news-stack">
      <NewsSearchPanel />
      <NewsResultsPanel />
    </div>
  </main>

  <script type="module" src={runNewsScript}></script>
</BaseLayout>

<style is:global>
  .page-shell--news {
    max-width: 1540px;
    padding-top: 28px;
  }

  .hero--news {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    border: 1px solid rgba(11, 52, 102, 0.09);
    background:
      radial-gradient(circle at top left, rgba(82, 151, 255, 0.12), transparent 36%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 249, 255, 0.94));
    box-shadow: 0 22px 60px rgba(80, 111, 172, 0.08);
  }

  .hero--news h1 {
    max-width: 13ch;
    color: #173a69;
  }

  .hero--news p {
    max-width: 64ch;
    color: #5a6981;
  }

  .hero-news__badge {
    min-width: 220px;
    border-radius: 28px;
    padding: 18px 20px;
    background: linear-gradient(180deg, rgba(220, 239, 255, 0.95), rgba(239, 247, 255, 0.88));
    color: #1b5b95;
    display: grid;
    gap: 4px;
    align-self: stretch;
    justify-content: end;
  }

  .hero-news__badge span {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .hero-news__badge strong {
    font-size: 1.05rem;
    line-height: 1.25;
  }

  .news-stack {
    display: grid;
    gap: 18px;
  }

  .news-toolbar {
    border: 1px solid rgba(19, 76, 136, 0.08);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(246, 250, 255, 0.95));
    box-shadow: 0 10px 24px rgba(57, 92, 154, 0.06);
  }

  .news-toolbar .panel-inner {
    padding: 10px 12px;
  }

  .news-toolbar__form {
    display: grid;
    gap: 8px;
  }

  .news-toolbar__heading {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: center;
  }

  .news-toolbar__eyebrow {
    margin: 0 0 2px;
    color: #6d7e98;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.52rem;
    font-weight: 700;
  }

  .news-toolbar__heading h2 {
    margin: 0;
    color: #154272;
    font-size: 0.95rem;
    line-height: 1.1;
  }

  .news-toolbar__button {
    background: #1a73e8;
    border-color: transparent;
    border-radius: 8px;
    box-shadow: 0 5px 12px rgba(26, 115, 232, 0.18);
    font-size: 0.72rem;
    padding: 6px 9px;
  }

  .news-toolbar__filters {
    display: grid;
    grid-template-columns: minmax(0, 1.65fr) minmax(280px, 0.9fr);
    gap: 8px;
  }

  .news-toolbar__search,
  .news-toolbar__meta label {
    display: grid;
    gap: 3px;
  }

  .news-toolbar__search span,
  .news-toolbar__meta span,
  .news-source-pills legend {
    color: #60728f;
    font-size: 0.56rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  .news-toolbar__meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 6px;
  }

  .news-toolbar .input {
    border-color: rgba(84, 112, 153, 0.22);
    border-radius: 8px;
    min-height: 28px;
    padding: 5px 8px;
    background: rgba(255, 255, 255, 0.95);
    font-size: 0.72rem;
  }

  .news-source-pills {
    margin: 0;
    padding: 0;
    border: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .news-source-pills legend {
    float: left;
    width: 100%;
    margin-bottom: 0;
    padding: 0;
  }

  .news-source-pill {
    position: relative;
    cursor: pointer;
  }

  .news-source-pill input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .news-source-pill span {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 0 8px;
    border-radius: 8px;
    border: 1px solid rgba(93, 112, 141, 0.28);
    background: rgba(255, 255, 255, 0.94);
    color: #35516f;
    font-size: 0.68rem;
    font-weight: 600;
    transition: 160ms ease;
  }

  .news-source-pill input:checked + span {
    background: #d8ecff;
    border-color: #d8ecff;
    color: #14679c;
  }

  .news-results-shell {
    display: grid;
    gap: 16px;
  }

  .news-status-strip {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }

  .news-status-strip__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .news-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.9fr) minmax(320px, 0.9fr);
    gap: 20px;
    align-items: start;
  }

  .news-cluster {
    border: 1px solid rgba(17, 56, 102, 0.08);
    border-radius: 28px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(249, 251, 255, 0.97));
    box-shadow: 0 24px 60px rgba(77, 102, 152, 0.08);
  }

  .news-cluster .panel-inner {
    padding: 26px 28px;
  }

  .news-cluster__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    color: #0b6899;
  }

  .news-cluster__header h2 {
    margin: 0;
    font-size: clamp(1.7rem, 2vw, 2.25rem);
    font-weight: 500;
    letter-spacing: -0.04em;
  }

  .news-cluster__arrow {
    font-size: 2rem;
    line-height: 1;
  }

  .news-cluster__divider {
    height: 1px;
    background: rgba(64, 94, 128, 0.16);
    margin: 22px 0 26px;
  }

  .lead-story {
    display: grid;
    gap: 20px;
  }

  .lead-story__headline {
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1.04;
    letter-spacing: -0.05em;
    text-decoration: none;
    color: #113a63;
  }

  .lead-story__grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.95fr) minmax(0, 1.15fr);
    gap: 20px;
    align-items: start;
  }

  .lead-story__art {
    min-height: 290px;
    border-radius: 24px;
    padding: 20px;
    display: flex;
    align-items: end;
    color: rgba(255, 255, 255, 0.92);
    font-size: 1.6rem;
    line-height: 1;
    letter-spacing: -0.04em;
    font-weight: 600;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.1), transparent 35%),
      linear-gradient(180deg, rgba(13, 28, 56, 0.06), rgba(13, 28, 56, 0.34));
  }

  .lead-story__body {
    display: grid;
    gap: 16px;
  }

  .story-source {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #334a67;
    font-size: 0.98rem;
    font-weight: 700;
  }

  .source-art {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.95);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    background: linear-gradient(180deg, #7890b4, #4a658d);
  }

  .source-art--default,
  .lead-story__art.source-art--default,
  .rail-story__art.source-art--default {
    background-image: linear-gradient(135deg, #7692ff, #3e5daa 72%);
  }

  .source-art--amber,
  .lead-story__art.source-art--amber,
  .rail-story__art.source-art--amber {
    background-image: linear-gradient(135deg, #ffb34d, #f2682f 72%);
  }

  .source-art--rose,
  .lead-story__art.source-art--rose,
  .rail-story__art.source-art--rose {
    background-image: linear-gradient(135deg, #ff8fb1, #e0597d 72%);
  }

  .source-art--orange,
  .lead-story__art.source-art--orange,
  .rail-story__art.source-art--orange {
    background-image: linear-gradient(135deg, #ff9866, #ee5b32 72%);
  }

  .source-art--violet,
  .lead-story__art.source-art--violet,
  .rail-story__art.source-art--violet {
    background-image: linear-gradient(135deg, #9b94ff, #665bdb 72%);
  }

  .source-art--mint,
  .lead-story__art.source-art--mint,
  .rail-story__art.source-art--mint {
    background-image: linear-gradient(135deg, #44d1a5, #0b8e75 72%);
  }

  .source-art--sky,
  .lead-story__art.source-art--sky,
  .rail-story__art.source-art--sky {
    background-image: linear-gradient(135deg, #68c8ff, #1976e8 72%);
  }

  .lead-story__summary {
    margin: 0;
    color: #33445d;
    font-size: 1.1rem;
    line-height: 1.55;
  }

  .lead-story__meta,
  .headline-row__meta,
  .rail-story__meta,
  .more-story__meta {
    margin: 0;
    color: #637089;
    font-size: 0.97rem;
    line-height: 1.5;
  }

  .headline-stack {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin-top: 24px;
  }

  .headline-row {
    padding-top: 10px;
    border-top: 1px solid rgba(78, 104, 135, 0.16);
    display: grid;
    gap: 10px;
  }

  .headline-row__link,
  .rail-story__link,
  .more-story__link {
    color: #2b3344;
    text-decoration: none;
    font-size: 1.03rem;
    line-height: 1.35;
  }

  .headline-row__link {
    font-size: 1rem;
  }

  .news-cluster__cta {
    margin-top: 28px;
    padding: 18px 24px;
    border-radius: 999px;
    background: #eff2f7;
    color: #45505f;
    text-align: center;
    font-size: 1rem;
    font-weight: 700;
  }

  .more-grid {
    display: grid;
    gap: 0;
    margin-top: 24px;
  }

  .more-story {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 16px;
    align-items: center;
    padding: 20px 0;
    border-top: 1px solid rgba(78, 104, 135, 0.16);
  }

  .more-story__source {
    margin: 0 0 8px;
    color: #4a5871;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .more-story__score {
    color: #9bb2cf;
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.06em;
  }

  .news-cluster--rail .news-cluster__header h2 {
    font-size: clamp(1.45rem, 1.7vw, 1.9rem);
  }

  .news-cluster__pill-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }

  .news-cluster__pill {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 16px;
    border: 1px solid rgba(93, 112, 141, 0.24);
    color: #41556f;
    background: #fff;
    font-weight: 600;
  }

  .news-cluster__pill--active {
    background: #d8ecff;
    border-color: #d8ecff;
    color: #14679c;
  }

  .rail-stack {
    display: grid;
    gap: 0;
  }

  .rail-story {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 102px;
    gap: 16px;
    padding: 18px 0;
    border-top: 1px solid rgba(78, 104, 135, 0.16);
    align-items: start;
  }

  .rail-stack .rail-story:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .rail-story__body {
    display: grid;
    gap: 10px;
  }

  .rail-story__art {
    min-height: 96px;
    border-radius: 18px;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.42), transparent 35%),
      linear-gradient(135deg, #7692ff, #3e5daa 72%);
  }

  .news-debug-block {
    margin-top: 4px;
    border-top: 0;
    padding-top: 0;
  }

  .news-debug-block pre {
    border-radius: 20px;
    border-color: rgba(84, 112, 153, 0.18);
    background: rgba(255, 255, 255, 0.92);
  }

  @media (max-width: 860px) {
    .hero--news {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-news__badge {
      min-width: 0;
      justify-content: start;
    }

    .news-toolbar__heading,
    .news-toolbar__filters {
      grid-template-columns: 1fr;
      flex-direction: column;
      align-items: stretch;
    }
  }

  @media (max-width: 1100px) {
    .news-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 900px) {
    .lead-story__grid,
    .headline-stack {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .page-shell--news {
      padding-top: 18px;
    }

    .news-cluster .panel-inner {
      padding: 18px;
    }

    .lead-story__headline {
      font-size: 1.7rem;
    }

    .lead-story__art {
      min-height: 200px;
    }

    .rail-story {
      grid-template-columns: 1fr;
    }

    .rail-story__art {
      min-height: 72px;
      order: -1;
    }

    .more-story {
      grid-template-columns: 1fr;
    }
  }
</style>
