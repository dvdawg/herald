---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsResultsPanel from "../components/NewsResultsPanel.astro";
import NewsSearchPanel from "../components/NewsSearchPanel.astro";
import runNewsScript from "../scripts/news.js?url";
---

<BaseLayout title="Herald News Radar" activePage="news">
  <main class="mx-auto grid max-w-[1540px] gap-[18px] px-3.5 pt-7 pb-12 sm:px-5">
    <section class="flex flex-col gap-6 rounded-[24px] border border-[rgba(11,52,102,0.09)] bg-[radial-gradient(circle_at_top_left,rgba(82,151,255,0.12),transparent_36%),linear-gradient(180deg,rgba(255,255,255,0.96),rgba(246,249,255,0.94))] px-4 py-4 shadow-[0_22px_60px_rgba(80,111,172,0.08)] sm:px-6 sm:py-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="mb-2.5 text-[0.78rem] font-bold uppercase tracking-[0.18em] text-accent">Herald News</p>
        <h1 class="max-w-[13ch] text-[clamp(2rem,4vw,3.7rem)] leading-[0.95] font-semibold tracking-[-0.05em] text-[#173a69]">
          Current events arranged like a morning briefing.
        </h1>
      </div>
      <div class="grid min-w-0 gap-1 self-stretch rounded-[28px] bg-[linear-gradient(180deg,rgba(220,239,255,0.95),rgba(239,247,255,0.88))] px-5 py-[18px] text-[#1b5b95] lg:min-w-[220px] lg:justify-end">
        <span class="text-[0.72rem] font-bold uppercase tracking-[0.12em]">Live feed</span>
        <strong class="text-[1.05rem] leading-[1.25] font-semibold">Communities + news desks</strong>
      </div>
    </section>

    <div class="grid gap-[18px]">
      <NewsSearchPanel />
      <NewsResultsPanel />
    </div>
  </main>

  <script type="module" src={runNewsScript}></script>
</BaseLayout>
