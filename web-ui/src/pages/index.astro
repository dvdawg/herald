---
import ResultsPanel from "../components/ResultsPanel.astro";
import SearchPanel from "../components/SearchPanel.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import runSearchScript from "../scripts/index.js?url";
---

<BaseLayout title="Herald Search UI" activePage="papers">
  <main class="page-shell">
    <section class="hero">
      <p class="hero-kicker">Herald</p>
      <h1>Paper Ranking</h1>
      <p>
        Scored ranking of papers based on a query.
      </p>
    </section>

    <div class="panel-grid">
      <SearchPanel />
      <ResultsPanel />
    </div>
  </main>

  <script type="module" src={runSearchScript}></script>
</BaseLayout>
