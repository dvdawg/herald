---
---

<section class="grid gap-4">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div id="news-error" class="min-h-5 text-[0.92rem] font-bold text-accent" aria-live="polite"></div>
    <div class="flex flex-wrap items-center gap-3">
      <span
        class="rounded-full border-[1.5px] border-line bg-paper-panel-strong px-2.5 py-1 text-xs font-bold uppercase tracking-[0.06em]"
        id="news-result-count">Awaiting Refresh</span
      >
      <span id="news-source-status" class="text-[0.88rem] text-muted" aria-live="polite"></span>
    </div>
  </div>

  <div id="news-results" class="grid items-start gap-5 xl:grid-cols-[minmax(0,1.9fr)_minmax(320px,0.9fr)]">
    <section class="rounded-[28px] border border-[rgba(17,56,102,0.08)] bg-[linear-gradient(180deg,rgba(255,255,255,0.98),rgba(249,251,255,0.97))] shadow-[0_24px_60px_rgba(77,102,152,0.08)]">
      <div class="p-6 sm:px-7 sm:py-[26px]">
        <div class="flex items-center justify-between gap-3 text-[#0b6899]">
          <h2 class="m-0 text-[clamp(1.7rem,2vw,2.25rem)] font-medium tracking-[-0.04em]">Top stories</h2>
          <span class="text-[2rem] leading-none">›</span>
        </div>
        <div class="my-[22px] h-px bg-[rgba(64,94,128,0.16)]"></div>
        <div class="rounded-[14px] border-2 border-dashed border-line-soft bg-[rgba(255,255,255,0.55)] p-[18px] text-muted">
          Refresh the feed to pull in live stories from the selected sources.
        </div>
      </div>
    </section>
  </div>

  <section class="mt-1 border-t-2 border-line pt-4">
    <h3 class="mb-2.5 text-[0.95rem] font-bold uppercase tracking-[0.08em]">Debug Payload</h3>
    <pre
      id="news-debug-json"
      class="m-0 overflow-x-auto whitespace-pre-wrap break-words rounded-xl border-[1.5px] border-line bg-white p-3">{}</pre>
  </section>
</section>
