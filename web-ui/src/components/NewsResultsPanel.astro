<section class="news-results-shell">
  <div class="news-status-strip">
    <div id="news-error" class="status-message" aria-live="polite"></div>
    <div class="news-status-strip__meta">
      <span class="panel-chip" id="news-result-count">Awaiting Refresh</span>
      <span id="news-source-status" class="status-meta" aria-live="polite"></span>
    </div>
  </div>

  <div id="news-results" class="news-layout">
    <section class="panel news-cluster news-cluster--primary">
      <div class="panel-inner">
        <div class="news-cluster__header">
          <h2>Top stories</h2>
          <span class="news-cluster__arrow">›</span>
        </div>
        <div class="news-cluster__divider"></div>
        <div class="empty-state">Refresh the feed to pull in live stories from the selected sources.</div>
      </div>
    </section>
  </div>

  <section class="debug-block news-debug-block">
    <h3>Debug Payload</h3>
    <pre id="news-debug-json">{}</pre>
  </section>
</section>
