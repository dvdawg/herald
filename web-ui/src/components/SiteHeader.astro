---
export interface Props {
  brandLabel?: string;
}

const { brandLabel = "Herald" } = Astro.props;
---

<header class="sticky top-0 z-10 border-b border-line-soft/70 bg-[rgba(251,247,239,0.88)] backdrop-blur-[16px]">
  <div class="mx-auto flex max-w-[1180px] flex-col items-start justify-between gap-4 px-3.5 py-4 sm:flex-row sm:items-center sm:px-5">
    <a class="text-sm font-extrabold uppercase tracking-[0.08em] no-underline" href="/">{brandLabel}</a>
    <nav class="flex flex-wrap gap-2.5" aria-label="Primary">
      <a class="inline-flex items-center rounded-full border border-line/20 bg-white/80 px-3 py-2 text-[0.88rem] font-bold no-underline transition-colors hover:bg-white" href="/">
        Paper Search
      </a>
      <a class="inline-flex items-center rounded-full border border-line/20 bg-white/80 px-3 py-2 text-[0.88rem] font-bold no-underline transition-colors hover:bg-white" href="/news">
        News Radar
      </a>
    </nav>
  </div>
</header>
